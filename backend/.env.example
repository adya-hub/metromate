# Backend environment variables for MetroMate
# Copy this to .env and fill in values

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# DMRC Real-Time API (optional)
# When not set the app gracefully falls back to GTFS static data.
# ──────────────────────────────────────────────────────────────────────────────
# METRO_API_BASE_URL=https://api.dmrc.co.in/v1
# METRO_API_KEY=your_api_key_here
